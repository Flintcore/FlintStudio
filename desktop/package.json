{
  "name": "flintstudio-desktop",
  "version": "0.50.0",
  "description": "FlintStudio 桌面版 - 一键安装、双击即运行",
  "main": "dist/main.js",
  "author": "FlintStudio",
  "license": "MIT",
  "scripts": {
    "build": "tsc && node scripts/download-redis.js && node scripts/copy-standalone.js",
    "download-redis": "node scripts/download-redis.js",
    "start": "electron .",
    "electron": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win nsis",
    "dist:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "electron-serve": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "adm-zip": "^0.5.10",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5"
  },
  "build": {
    "appId": "ai.flintstudio.desktop",
    "productName": "FlintStudio",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "resources/**/*"],
    "extraResources": [{ "from": "resources/redis/", "to": "redis/", "filter": ["**/*"] }],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FlintStudio"
    }
  }
}
